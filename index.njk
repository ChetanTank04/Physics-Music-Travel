---
permalink: /
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Physics &middot; Music &middot; Travel &mdash; the public journal of a teacher</title>
<meta name="description" content="The public journal of Chetan Tank &mdash; physics, Hindustani music, travel, poetry, and letters to self.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;1,400&family=Noto+Serif+Gujarati:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">
</head>
<body>
<aside class="spine" aria-hidden="true">
  <span class="title">Physics &middot; Music &middot; Travel</span>
  <span class="seal">ચે</span>
</aside>
<div class="page">
  <header class="site">
    <p class="eyebrow fade">Bhavnagar &middot; since 2020</p>
    <h1 class="masthead fade d2">Physics<span class="dot">&middot;</span>Music<span class="dot">&middot;</span>Travel</h1>
    <p class="subtitle fade d3">The public journal of a teacher &mdash; notes kept the way one keeps a diary: imperfect, unhurried, and honest.</p>
    <p class="gujarati fade d3">&mdash; એક શિક્ષકની જાહેર ડાયરી</p>
    <nav class="cats" aria-label="Categories"><button aria-pressed="true" data-filter="all">All entries</button><button aria-pressed="false" data-filter="letters">Letters to self</button><button aria-pressed="false" data-filter="physics">Physics</button><button aria-pressed="false" data-filter="music">Music</button><button aria-pressed="false" data-filter="travel">Travel</button><button aria-pressed="false" data-filter="reading">Daily reading</button><button aria-pressed="false" data-filter="nostalgia">Nostalgia</button><button aria-pressed="false" data-filter="poetry">Poetry</button></nav>
  </header>
  <main class="stream">
    <svg class="seam" viewBox="0 0 26 4800" preserveAspectRatio="none" aria-hidden="true">
      <path d="M13 0 C 11 200, 17 380, 12 560 S 8 900, 14 1100 C 18 1320, 9 1520, 13 1740 S 19 2100, 11 2320 C 8 2540, 16 2760, 12 2980 S 10 3400, 14 3660 C 16 3900, 11 4200, 13 4500 S 12 4700, 13 4800"/>
      <circle cx="12.4" cy="220" r="3"/><circle cx="13.6" cy="1250" r="3"/>
      <circle cx="12.2" cy="2330" r="3"/><circle cx="13.2" cy="3400" r="3"/>
      <circle cx="12.8" cy="4400" r="3"/>
    </svg>
    {% for p in collections.post | reverse %}
    <article class="entry{% if not p.data.image %} noart{% endif %}" data-cats="{{ p.data.categories | join(' ') }}">
      <div class="body">
        <p class="date">{{ p.data.date | dispDate }} &middot; <span class="cat">{% for c in p.data.categories %}{{ catNames[c] }}{% if not loop.last %} &middot; {% endif %}{% endfor %}</span></p>
        <h2><a href="{{ p.url }}">{{ p.data.title }}</a></h2>
        <p>{{ p.data.excerpt }}</p>
        <a class="more" href="{{ p.url }}">Read the entry &rarr;</a>
      </div>
      {% if p.data.image %}<div class="art"><img src="{{ p.data.image }}" alt="" loading="lazy"></div>{% endif %}
    </article>
    {% endfor %}
  </main>
<section class="foot-grid">
    <div>
      <h3>Subscribe</h3>
      <p>An occasional letter when a new entry is written. No noise, no schedule &mdash; like the journal itself.</p>
      <div class="sub">
        <input type="email" placeholder="Your email address" aria-label="Email address">
        <button type="button">Subscribe</button>
      </div>
    </div>
    <div>
      <h3>Contact</h3>
      <p><a href="mailto:chetan.tank@yahoo.com">chetan.tank@yahoo.com</a></p>
      <div class="social">
        <a href="https://www.facebook.com/chetan.tank4">Facebook</a>
        <a href="https://www.instagram.com/chetan_tank04061983/">Instagram</a>
        <a href="https://www.linkedin.com/in/chetan-tank-61375476/">LinkedIn</a>
      </div>
    </div>
  </section>
  <footer class="site">
    <span>&copy; 2026 Chetan Tank &middot; Physics &middot; Music &middot; Travel</span>
    <span class="guj">અપૂર્ણતામાં જ સૌંદર્ય છે</span>
  </footer>
</div>
<script>
document.querySelectorAll('nav.cats button').forEach(function(btn){
  btn.addEventListener('click', function(){
    document.querySelectorAll('nav.cats button').forEach(function(b){b.setAttribute('aria-pressed','false')});
    btn.setAttribute('aria-pressed','true');
    var f = btn.dataset.filter;
    document.querySelectorAll('.entry').forEach(function(e){
      e.classList.toggle('hidden', f !== 'all' && e.dataset.cats.split(' ').indexOf(f) === -1);
    });
  });
});
</script>
</body>
</html>
